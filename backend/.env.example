# Irerero Backend — Environment Variables
# Copy this file to .env and fill in the values before running.

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 0.0.0.0

# PostgreSQL
DB_NAME=irerero_db
DB_USER=irerero
DB_PASSWORD=irerero2025
DB_HOST=localhost
DB_PORT=5432

# Redis (Celery + Django Channels)
REDIS_URL=redis://localhost:6379/0

# SMS Provider — "mock" for demo, "africas_talking" for production
SMS_PROVIDER=mock
AT_USERNAME=sandbox
AT_API_KEY=

# Firebase Cloud Messaging
FCM_SERVER_KEY=
FIREBASE_CREDENTIALS_PATH=

# CORS (React dashboard origin)
CORS_ORIGINS=http://localhost:3000
